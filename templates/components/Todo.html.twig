<div {{ attributes }} class="container mt-4 p-4 border rounded shadow-sm bg-light">
    <h2 class="mb-3 text-center">Ma Todo List avec LiveComponent</h2>

    <!-- Statistiques -->
    {{ component('TodoStats', {
        total: this.totalTodos,
        remaining: this.remaining,
        completed: this.completedCount
    }) }}

   {{ component('TodoSearchForm', { search: this.search }) }}

    <!-- Liste des tâches -->
    <ul class="list-group mb-5">
        {% for todo in this.todos %}
            <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                <div class="d-flex align-items-center flex-grow-1">
                    <!-- Checkbox live_action="toggleTodo"  -->
                    <input 
                        type="checkbox"
                        class="form-check-input me-3"
                        {% if todo.isDone() %}checked{% endif %}
                        {{ live_action('toggleTodo', { id: todo.getId() }) }}
                    >

                    {% if this.editingId == todo.getId() %}
                        <!-- Mode édition -->
                        <div class="d-flex flex-grow-1 gap-2">
                            <input 
                                type="text"
                                class="form-control form-control-sm"
                                data-model="editingTitle"
                                data-model-debounce="300"
                                autofocus
                           >
                            <!-- live_action="saveEdit" -->
                            <button 
                                type="button"
                                class="btn btn-sm btn-success"
                                {{ live_action('saveEdit') }}
                            >
                                Enregistrer
                            </button>

                            <!-- live_action="cancelEdit" -->
                            <button 
                                type="button"
                                class="btn btn-sm btn-outline-secondary"
                                {{ live_action('cancelEdit') }}
                            >
                                Annuler
                            </button>
                        </div>
                    {% else %}
                        <!-- Affichage normal -->
                        <span class="flex-grow-1 {{ todo.isDone() ? 'text-decoration-line-through text-muted' : '' }}">
                            {{ todo.getTitle() }}
                        </span>
                        <!-- live_action="startEdit" -->
                        <button
                             type="button"
                            class="btn btn-sm btn-outline-primary ms-3"
                            {{ live_action('startEdit', { id: todo.getId() }) }}
                        >
                            Modifier
                        </button>
                    {% endif %}
                </div>

                <!-- Bouton Supprimer -->
                 <!-- live_action="removeTodo" -->
                <button 
                    type="button"
                    class="btn btn-sm btn-danger ms-2"
                    {{ live_action('removeTodo', { id: todo.getId() }) }}
                >
                    Supprimer
                </button>
            </li>
        {% else %}
            <li class="list-group-item text-muted text-center py-4">
                Aucune tâche pour le moment...
            </li>
        {% endfor %}
    </ul>

    <!-- Ajout d'une nouvelle tâche -->
     {#<twig:TodoForm/>#}
     {{ component('TodoForm') }}
</div>
